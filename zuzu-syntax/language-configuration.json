{
	"comments": {
		"lineComment": "//",
		"blockComment": [
			"/*",
			"*/"
		]
	},
	"brackets": [
		["{", "}"],
		["[", "]"],
		["(", ")"],
		["{{", "}}"],
		["<<", ">>"],
		["<<<", ">>>"],
		["«", "»"],
		["⌊", "⌋"],
		["⌈", "⌉"]
	],
	"autoClosingPairs": [
		["{", "}"],
		["[", "]"],
		["(", ")"],
		["\"", "\""],
		["'", "'"],
		["`", "`"],
		["«", "»"],
		["⌊", "⌋"],
		["⌈", "⌉"]
	],
	"surroundingPairs": [
		["{", "}"],
		["[", "]"],
		["(", ")"],
		["\"", "\""],
		["'", "'"],
		["`", "`"],
		["«", "»"],
		["⌊", "⌋"],
		["⌈", "⌉"]
	],
	"folding": {
		"markers": {
			"start": "^\\s*(?://\\s*#?region\\b|(?:(?:async|static)\\s+){0,2}(?:class|trait|function|method)\\b.*\\{\\s*(?://.*)?$)",
			"end": "^\\s*(?://\\s*#?endregion\\b|\\})"
		}
	},
	"indentationRules": {
		"increaseIndentPattern": "^\\s*.*(?:\\{[^}\"']*|\\[[^\\]\"']*|\\([^\\)\"']*)$",
		"decreaseIndentPattern": "^\\s*[\\}\\]\\)].*$"
	}
}
