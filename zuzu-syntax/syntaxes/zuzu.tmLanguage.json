{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "ZuzuScript",
	"scopeName": "source.zuzu",
	"fileTypes": [
		"zzs",
		"zzm"
	],
	"firstLineMatch": "^#!/.*\\bzuzu\\b",
	"patterns": [
		{
			"include": "#pod"
		},
		{
			"include": "#comments"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#constants"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#regexps"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#operators"
		}
	],
	"repository": {
		"pod": {
			"patterns": [
				{
					"name": "comment.block.documentation.pod.zuzu",
					"begin": "^(=(?!cut\\b)\\w.*)$",
					"beginCaptures": {
						"1": {
							"name": "punctuation.definition.comment.begin.pod.zuzu"
						}
					},
					"end": "^(=cut)\\s*$",
					"endCaptures": {
						"1": {
							"name": "punctuation.definition.comment.end.pod.zuzu"
						}
					}
				}
			]
		},
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.zuzu",
					"match": "//.*$"
				},
				{
					"name": "comment.block.zuzu",
					"begin": "/\\*",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.comment.begin.zuzu"
						}
					},
					"end": "\\*/",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.comment.end.zuzu"
						}
					}
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "storage.type.class.zuzu",
					"match": "\\b(class|trait|extends|with|but)\\b"
				},
				{
					"name": "storage.type.function.zuzu",
					"match": "\\b(function|method|fn|static|async)\\b"
				},
				{
					"name": "keyword.control.flow.zuzu",
					"match": "\\bdefault\\b(?=\\s*:)"
				},
				{
					"name": "keyword.control.flow.zuzu",
					"match": "\\b(if|else|unless|while|for|switch|case|return|next|continue|last|try|catch|throw|die|do|await|spawn)\\b"
				},
				{
					"name": "storage.modifier.zuzu",
					"match": "\\b(let|const|from|import|as|new|self|super|weak)\\b"
				},
				{
					"name": "keyword.operator.word.zuzu",
					"match": "\\b(and|or|xor|nand|not|in|instanceof|does|can|typeof|default|mod|union|intersection|subsetof|supersetof|equivalentof|eqi|nei|gti|gei|lti|lei|cmpi|eq|ne|gt|ge|lt|le|cmp|abs|sqrt|floor|ceil|round|int|length|uc|lc)\\b"
				},
				{
					"name": "storage.modifier.accessor.zuzu",
					"match": "\\b(get|set|clear|has)\\b"
				},
				{
					"name": "support.class.builtin.zuzu",
					"match": "\\b(Any|Array|AssertionException|Bag|BinaryString|Boolean|CancelledException|ChannelClosedException|Class|Collection|Dict|Exception|Function|Null|Number|Object|Pair|PairList|Regexp|Set|String|Task|TimeoutException|Trait|TypeException)\\b"
				},
				{
					"name": "support.function.builtin.zuzu",
					"match": "\\b(warn|say|print|debug|assert)\\b"
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.language.boolean.zuzu",
					"match": "\\b(true|false)\\b|[⊤⊥]"
				},
				{
					"name": "constant.language.null.zuzu",
					"match": "\\bnull\\b"
				},
				{
					"name": "constant.other.empty-set.zuzu",
					"match": "∅"
				},
				{
					"name": "constant.language.system.zuzu",
					"match": "\\b(__argc__|__file__|__global__|__system__)\\b"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.zuzu",
					"match": "\\b(?:0x[\\da-fA-F]+|0b[01]+|\\d+(?:\\.\\d+)?(?:e[+-]?\\d+)?)\\b"
				}
			]
		},
		"regexps": {
			"patterns": [
				{
					"name": "string.regexp.zuzu",
					"begin": "/(?![/*=\\s])(?=(?:\\\\.|\\[[^\\]\\\\]*(?:\\\\.[^\\]\\\\]*)*\\]|\\$\\{[^}]*\\}|[^/\\\\\\n])+/[ig]*)",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.zuzu"
						}
					},
					"end": "/[ig]*",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.zuzu"
						}
					},
					"patterns": [
						{
							"name": "constant.character.escape.zuzu",
							"match": "\\\\."
						},
						{
							"name": "meta.interpolation.zuzu",
							"begin": "\\$\\{",
							"beginCaptures": {
								"0": {
									"name": "punctuation.section.embedded.begin.zuzu"
								}
							},
							"end": "\\}",
							"endCaptures": {
								"0": {
									"name": "punctuation.section.embedded.end.zuzu"
								}
							},
							"patterns": [
								{
									"include": "$self"
								}
							]
						}
					]
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.block.zuzu",
					"begin": "\"\"\"",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.zuzu"
						}
					},
					"end": "\"\"\"",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.zuzu"
						}
					}
				},
				{
					"name": "string.quoted.single.block.zuzu",
					"begin": "'''",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.zuzu"
						}
					},
					"end": "'''",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.zuzu"
						}
					}
				},
				{
					"name": "string.template.backtick.block.zuzu",
					"begin": "```",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.zuzu"
						}
					},
					"end": "```",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.zuzu"
						}
					},
					"patterns": [
						{
							"name": "constant.character.escape.zuzu",
							"match": "\\\\."
						},
						{
							"name": "meta.interpolation.zuzu",
							"begin": "\\$\\{",
							"beginCaptures": {
								"0": {
									"name": "punctuation.section.embedded.begin.zuzu"
								}
							},
							"end": "\\}",
							"endCaptures": {
								"0": {
									"name": "punctuation.section.embedded.end.zuzu"
								}
							},
							"patterns": [
								{
									"include": "$self"
								}
							]
						}
					]
				},
				{
					"name": "string.template.backtick.zuzu",
					"begin": "`",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.zuzu"
						}
					},
					"end": "`",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.zuzu"
						}
					},
					"patterns": [
						{
							"name": "constant.character.escape.zuzu",
							"match": "\\\\."
						},
						{
							"name": "meta.interpolation.zuzu",
							"begin": "\\$\\{",
							"beginCaptures": {
								"0": {
									"name": "punctuation.section.embedded.begin.zuzu"
								}
							},
							"end": "\\}",
							"endCaptures": {
								"0": {
									"name": "punctuation.section.embedded.end.zuzu"
								}
							},
							"patterns": [
								{
									"include": "$self"
								}
							]
						}
					]
				},
				{
					"name": "string.quoted.single.zuzu",
					"begin": "'",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.zuzu"
						}
					},
					"end": "'",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.zuzu"
						}
					},
					"patterns": [
						{
							"name": "constant.character.escape.zuzu",
							"match": "\\\\."
						}
					]
				},
				{
					"name": "string.quoted.double.zuzu",
					"begin": "\"",
					"beginCaptures": {
						"0": {
							"name": "punctuation.definition.string.begin.zuzu"
						}
					},
					"end": "\"",
					"endCaptures": {
						"0": {
							"name": "punctuation.definition.string.end.zuzu"
						}
					},
					"patterns": [
						{
							"name": "constant.character.escape.zuzu",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.assignment.zuzu",
					"match": "\\*\\*=|\\?:=|:=|~=|\\+=|-=|\\*=|/=|×=|÷=|_="
				},
				{
					"name": "keyword.operator.increment-decrement.zuzu",
					"match": "\\+\\+|--"
				},
				{
					"name": "keyword.operator.lambda.zuzu",
					"match": "->|→"
				},
				{
					"name": "variable.language.placeholder.zuzu",
					"match": "\\^\\^"
				},
				{
					"name": "keyword.operator.chain.zuzu",
					"match": "▷|◁|\\|>|<\\|"
				},
				{
					"name": "punctuation.separator.zuzu",
					"match": "\\?:|\\.\\.\\.|\\.\\(|,|;|\\.|:|\\?"
				},
				{
					"name": "punctuation.section.braces.begin.zuzu",
					"match": "<<<|\\{\\{|\\{|\\[|\\(|<<|«|⌊|⌈"
				},
				{
					"name": "punctuation.section.braces.end.zuzu",
					"match": ">>>|\\}\\}|\\}|\\]|\\)|>>|»|⌋|⌉"
				},
				{
					"name": "keyword.operator.comparison.zuzu",
					"match": "<=>|==|!=|<=|>=|≠|≤|≥|≡|≢|≶|≷|=|<|>"
				},
				{
					"name": "keyword.operator.arithmetic.zuzu",
					"match": "\\*\\*|\\+|-|\\*|×|/|÷|_|@\\?|@@|@|√"
				},
				{
					"name": "keyword.operator.logical.zuzu",
					"match": "⋀|⋁|⊻|⊼|¬|!|~"
				},
				{
					"name": "keyword.operator.bitwise.zuzu",
					"match": "&|\\^|\\|"
				},
				{
					"name": "keyword.operator.collection.zuzu",
					"match": "∈|∉|⋃|⋂|\\\\|∖|⊂⊃|⊂|⊃"
				}
			]
		}
	}
}
